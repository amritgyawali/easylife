# =============================================================================
# Amrit LifeOS — environment configuration
#
# Copy this file to `.env` for local development. Never commit `.env`.
#
# CLIENT-SAFE variables (prefixed EXPO_PUBLIC_) are bundled into the app and
# are visible to anyone who inspects the compiled JS or web bundle. Only put
# values here that are safe to expose (a Supabase anon key is designed to be
# public — it has no power beyond what Row Level Security allows).
#
# SERVER-ONLY variables must NEVER be prefixed EXPO_PUBLIC_. They are used
# only by Supabase Edge Functions (supabase/functions) and Vercel serverless
# functions, configured directly in the Supabase dashboard / Vercel project
# settings — not shipped in the Expo app bundle.
# =============================================================================

# --- Client-safe (EXPO_PUBLIC_*) ---------------------------------------------

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_APP_URL=http://localhost:8081
EXPO_PUBLIC_APP_NAME=Amrit LifeOS
EXPO_PUBLIC_DEFAULT_TIMEZONE=Asia/Kathmandu
EXPO_PUBLIC_DEFAULT_CURRENCY=NPR

# --- Server-only (Supabase Edge Function secrets / Vercel project env) ------
# Set these with `supabase secrets set NAME=value` for Edge Functions, and in
# the Vercel dashboard for any serverless API routes. Do NOT add these to the
# Expo app's .env — they must never reach the client bundle.

SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
DOCUMENT_PROCESSING_SECRET=
CRON_SECRET=

# Free-tier usage protection limits. Never hardcoded in application code —
# always read from here so limits can be tuned without a code change as
# Supabase/Resend free-tier quotas evolve.
MAX_UPLOAD_MB=15
MAX_PDF_PAGES=20
MAX_DAILY_EXTRACTIONS=25
MAX_DAILY_EMAILS=50
